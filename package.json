*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --bg: #ffffff;
  --bg2: #f5f5f4;
  --bg3: #eeece8;
  --text: #1a1a1a;
  --text2: #6b7280;
  --border: rgba(0,0,0,0.1);
  --green: #1D9E75;
  --red: #D85A30;
  --blue: #378ADD;
}

@media (prefers-color-scheme: dark) {
  :root {
    --bg: #1a1a1a;
    --bg2: #242424;
    --bg3: #2e2e2e;
    --text: #f0ede8;
    --text2: #9ca3af;
    --border: rgba(255,255,255,0.1);
  }
}

body {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  background: var(--bg3);
  color: var(--text);
  min-height: 100vh;
}
